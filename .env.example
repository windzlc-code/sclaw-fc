SITE_NAME=日本不動產全球指定搜尋網
BRAND_NAME=
# 對外正式網址（canonical）：預設 www；亦可在後台「站台／DNS」覆寫 public_site_url
SITE_URL=https://www.manuvip.com
# Docker/Caddy 用：僅根網域標籤，勿含 www（用於 www.{DOMAIN} 與 {DOMAIN} 兩段設定）
# DOMAIN=manuvip.com

# 正式環境建議：停用「web server 進程內」背景排程（避免多 worker / 多副本重複執行造成 DB 鎖與流量干擾）
# 需要時可設 1 啟用（通常僅建議在單一 worker、且確定可承受額外抓取流量時）
SCLAW_ENABLE_BACKGROUND_WORKERS=0

# Portal image_urls backfill worker (enabled when SCLAW_ENABLE_BACKGROUND_WORKERS=1)
# comma-separated host keys; empty = all supported
SCLAW_PORTAL_IMAGE_BACKFILL_HOSTS=suumo.jp
SCLAW_PORTAL_IMAGE_BACKFILL_LIMIT=18
SCLAW_PORTAL_IMAGE_BACKFILL_SLEEP=0.35
SCLAW_PORTAL_IMAGE_BACKFILL_INTERVAL_SEC=900

# 上線穩定查詢建議：
# - 站內案件查詢結果加上短期快取（秒）；避免高頻重查造成 DB 壓力與結果抖動
# - 停用「查詢時即時補抓縮圖」：可避免外站 WAF/限流導致查詢忽快忽慢、且避免把不穩定資料寫回
SCLAW_PORTAL_SEARCH_CACHE_TTL=120
SCLAW_PORTAL_SEARCH_LIVE_BACKFILL=0

# 本機快取維護：定期清理過期圖片／縮圖／海報快取，避免伺服器磁碟長期膨脹。
# 只處理 static/cache 下的生成物，不刪除資料庫與正式素材。
SCLAW_CACHE_MAINTENANCE=1
SCLAW_CACHE_MAINTENANCE_INTERVAL_SEC=21600
SCLAW_CACHE_MAINTENANCE_INITIAL_DELAY_SEC=45
SCLAW_CACHE_MAINTENANCE_MAX_DELETE_FILES=12000
SCLAW_CACHE_CASE_IMAGES_MAX_AGE_DAYS=45
SCLAW_CACHE_CASE_IMAGES_MAX_BYTES=6442450944
SCLAW_CACHE_CASE_THUMBS_MAX_AGE_DAYS=14
SCLAW_CACHE_CASE_THUMBS_MAX_BYTES=1610612736
SCLAW_CACHE_HOME_POSTERS_MAX_AGE_DAYS=30
SCLAW_CACHE_HOME_POSTERS_MAX_BYTES=536870912

# 案件頁即時補抓寫回 DB：上線初期建議停用（穩定優先）；需要自動修復缺圖/缺欄位時再開啟
SCLAW_PERSIST_LIVE_ENRICH=0

# 後台管理密碼（選填；若存在 data/admin_panel_password.txt 則以檔案為準）
# ADMIN_PANEL_PASSWORD=

# LINE Messaging API（也可在後台「LINE/TG」儲存到本機 app_kv；正式密鑰請勿提交）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
# LINE_STAFF_USER_ID=
# LINE_WEBHOOK_URL=

# 預設 AI 供應商：deepseek（預設）或 gemini；亦可在後台「AI 供應商」覆寫
# 後台「客服 Q&A 生成」等會依「目前選用的供應商」檢查：該組必須同時有 Base URL 與 API Key，否則會 503。
LLM_ACTIVE_PROVIDER=deepseek

# DeepSeek（OpenAI 相容：POST {BASE}/v1/chat/completions）
DEEPSEEK_BASE_URL=https://api.tu-zi.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v3.2

# Gemini（OpenAI 相容代理，例如 new-api / one-api；與 DeepSeek 二選一設定即可，但若 LLM_ACTIVE_PROVIDER=gemini 或後台選 Gemini 則必須填以下）
GEMINI_BASE_URL=http://127.0.0.1:3008
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-3-flash

# 供應商文件連結（選填；後台可覆寫）
LLM_DOCS_URL=https://tuzi-api.apifox.cn/343647063e0

# Google Custom Search JSON API（地產／金融／貸款關鍵字擷取）
# 建立方式：https://programmablesearchengine.google.com/ → 取得 Search engine ID (cx)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# 爬文入 content_items 前閘門（source_items 仍會寫入）
# off=關閉（預設） | rules=僅規則 | ai=規則通過後再以 LLM JSON 決定是否入庫（LLM 失敗時不阻擋，僅略過 AI 步驟）
SCLAW_INGEST_GATE_MODE=off
# 規則：簡中正文至少字數（過短不入庫；jp_listing、suumo_faq 類型一律放行）
SCLAW_INGEST_RULE_MIN_CHARS=40
# 選填：AI 閘門指定供應商／模型（預設與站內 LLM 相同）
# SCLAW_INGEST_AI_PROVIDER=
# SCLAW_INGEST_AI_MODEL=

# SUUMO 限流恢復保護：預設少量探測、慢速抓取；遇到 403/429 或限流頁會自動冷卻。
# SCLAW_SUUMO_HUB_CAP=4
# SCLAW_SUUMO_CHINTAI_MAX_PAGES=4
# SCLAW_SUUMO_REQUEST_INTERVAL_SEC=6
# SCLAW_SUUMO_COOLDOWN_MINUTES=180
# SCLAW_SUUMO_PAUSE=0
# SCLAW_SUUMO_PLAYWRIGHT=0

# Cloud phone publishing bridge
ADBFACEBOOK_WEB_URL=http://127.0.0.1:8080
SCLAW_VMOS2_LABEL=另一個 VMOS CLOUD
SCLAW_VMOS2_API_HOST=api.vmoscloud.com
SCLAW_VMOS2_ACCESS_KEY=
SCLAW_VMOS2_SECRET_KEY=
